/* ── GLOBAL BLUR BACKGROUND (cycles through all field photos) ── */
(function() {
  const allPhotos = [
    FIMGS[1], FIMGS[2], FIMGS[3], FIMGS[4], FIMGS[5], FIMGS[6], FIMGS[7]
  ];
  let bgIdx = 0;

  // Create two layers for crossfade
  function createLayer(zIdx) {
    const el = document.createElement('div');
    el.style.cssText = `
      position:fixed; inset:0; z-index:${zIdx};
      background-size:cover; background-position:center;
      filter:blur(36px) brightness(.22) saturate(.5) contrast(1.1);
      transform:scale(1.06);
      transition:opacity 2.5s ease;
      pointer-events:none;
    `;
    document.body.insertBefore(el, document.body.firstChild);
    return el;
  }

  const layerA = createLayer(0);
  const layerB = createLayer(0);
  layerA.style.opacity = '1';
  layerB.style.opacity = '0';
  let activeLayer = layerA;
  let hiddenLayer = layerB;

  function setBg(el, src) { el.style.backgroundImage = `url(${src})`; }

  setBg(layerA, allPhotos[0]);
  setBg(layerB, allPhotos[1]);

  // Slow crossfade every ~12s, synced loosely with slides
  setInterval(() => {
    bgIdx = (bgIdx + 1) % allPhotos.length;
    setBg(hiddenLayer, allPhotos[bgIdx]);
    hiddenLayer.style.opacity = '1';
    activeLayer.style.opacity = '0';
    const tmp = activeLayer;
    activeLayer = hiddenLayer;
    hiddenLayer = tmp;
    // Pre-load next
    setTimeout(() => {
      setBg(hiddenLayer, allPhotos[(bgIdx + 1) % allPhotos.length]);
    }, 3000);
  }, 12000);
})();

