function addSlide(stage, idx, bgSrc, overlay, layout, inner) {
  const el = document.createElement('div');
  el.className = 'slide';
  el.id = 'sl' + idx;
  el.innerHTML = inner;
  stage.appendChild(el);

  // spawn particles
  setTimeout(() => {
    const bg = el.querySelector('.s-bg-img, .s-bg-color');
    if (!bg) return;
    for (let p=0; p<14; p++) {
      const pt = document.createElement('div');
      pt.className = 'pt';
      const sz = Math.random()*2+1;
      pt.style.cssText = `width:${sz}px;height:${sz}px;left:${Math.random()*100}%;bottom:${Math.random()*15}%;
        --dx:${(Math.random()-.5)*100}px;
        animation-duration:${Math.random()*14+9}s;animation-delay:${Math.random()*12}s;`;
      el.appendChild(pt);
    }
  }, 200);
}

/* ── STATE ── */
let cur = 0, total = 8, auto = null;
const INTERVAL = 9000;

buildSlides();

/* ── DOTS ── */
const dotsEl = document.getElementById('dots');
for (let i=0;i<total;i++) {
  const d = document.createElement('div');
  d.className = 'dot' + (i===0?' on':'');
  d.onclick = ()=> goTo(i);
  dotsEl.appendChild(d);
}

/* ── TIMER ── */
const tline = document.getElementById('timeline');
function startAuto() {
  clearInterval(auto);
  tline.style.transition = 'none';
  tline.style.width = '0%';
  void tline.offsetWidth;
  tline.style.transition = `width ${INTERVAL}ms linear`;
  tline.style.width = '100%';
  auto = setInterval(()=> goTo((cur+1)%total), INTERVAL);
}

/* ── GO TO ── */
function goTo(idx) {
  const fl = document.getElementById('flash');
  fl.classList.add('on');
  setTimeout(()=> {
    document.querySelectorAll('.slide').forEach(s=>s.classList.remove('active'));
    cur = (idx+total)%total;
    document.getElementById('sl'+cur).classList.add('active');
    document.querySelectorAll('.dot').forEach((d,i)=>d.className='dot'+(i===cur?' on':''));
    document.getElementById('tbCount').textContent =
      String(cur+1).padStart(2,'0')+' / '+String(total).padStart(2,'0');
    fl.classList.remove('on');
    startAuto();
  }, 260);
}
function navigate(dir) { goTo(cur+dir); }

/* ── KEYBOARD ── */
document.addEventListener('keydown', e=>{
  if(e.key==='ArrowRight'||e.key===' ') { e.preventDefault(); navigate(1); }
  if(e.key==='ArrowLeft') navigate(-1);
  if(e.key==='Escape') { clearInterval(auto); tline.style.width='0%'; }
});

/* ── SWIPE ── */
let tx0=0;
document.addEventListener('touchstart',e=>{tx0=e.touches[0].clientX;});
document.addEventListener('touchend',e=>{
  const dx=e.changedTouches[0].clientX-tx0;
  if(Math.abs(dx)>50) navigate(dx<0?1:-1);
});

/* ── CURSOR ── */
const cur_el = document.getElementById('cursor');
document.addEventListener('mousemove',e=>{
  cur_el.style.left=e.clientX+'px';
  cur_el.style.top=e.clientY+'px';
});
document.querySelectorAll('.nav,.dot').forEach(el=>{
  el.addEventListener('mouseenter',()=>cur_el.classList.add('big'));
  el.addEventListener('mouseleave',()=>cur_el.classList.remove('big'));
});

/* ── START ── */
goTo(0);
